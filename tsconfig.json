{
  "compilerOptions": {
    "target": "es2022",
    "lib": [
      "es2022", "dom"
    ],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "removeComments": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "types":  [
      "cypress", "node"
    ]
  },
  "include": ["./src/**/*"],
  "exclude": ["dist", "node_modules"]
}
