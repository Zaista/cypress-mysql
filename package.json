  "license": "MIT",
  "homepage": "https://github.com/Zaista/cypress-mysql",
  "bugs": "https://github.com/Zaista/cypress-mysql/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Zaista/cypress-mysql.git"
  },
  "files": [
    "dist/index.js",
    "dist/index.d.ts"
  ],
  "dependencies": {
    "mysql2": "3.22.3"
  },
  "peerDependencies": {
    "cypress": ">=15"
  },
  "devDependencies": {
    "@types/mocha": "10.0.10",
    "@types/node": "25.8.0",
    "mocha": "11.7.5",
